# Copy this to apps/web/.env.local (gitignored) and fill in your real key.
# DO NOT commit this file with real values — .env.local is in .gitignore.
#
# IMPORTANT: If your API key has ever been exposed (shared in chat, pasted in a public place, etc.),
# rotate it immediately at https://aistudio.google.com/apikey before using.

# Standard Google AI Studio key format: AIza... (39 characters)
GEMINI_API_KEY=your-gemini-key-here

# Default model. Falls back to gemini-2.5-pro if 3.x not available.
GEMINI_MODEL=gemini-2.5-pro

# Optional: explicit repo root override. Auto-detected if omitted.
# NOVELWRIGHT_REPO_ROOT=
