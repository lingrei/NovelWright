# NovelWright environment configuration template
# Copy this to .env.local (gitignored) and fill in real values for local dev.
# In production, use Fly.io secrets / Vercel env vars — never commit real keys.

# --- LLM Provider ---
# The Google API key used for all Gemini calls. Required server-side.
# Get one from https://aistudio.google.com/apikey (format: AIza...)
GEMINI_API_KEY=your-gemini-key-here

# Default Gemini model. Override per request if needed.
# Options: gemini-2.5-pro, gemini-3-pro (when available), gemini-3.1-pro (when available)
GEMINI_MODEL=gemini-2.5-pro

# --- Cost Controls ---
# Per-project hard cap (USD). Auto-pauses at 80% of this value.
COST_CAP_USD_PER_PROJECT=20

# --- Orchestrator (Fly.io) ---
# Public URL of the long-running Write-phase orchestrator.
# In dev, point to local: http://localhost:4000
ORCHESTRATOR_URL=http://localhost:4000

# Shared secret between web app and orchestrator for internal calls.
# Generate with: openssl rand -hex 32
ORCHESTRATOR_SECRET=change-me-to-a-random-hex-string

# --- Persistence ---
# Redis URL for orchestrator state (Upstash, Fly Redis, or local).
# In dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# --- Observability (optional in dev) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
